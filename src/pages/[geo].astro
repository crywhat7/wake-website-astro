---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Header from '../components/home/Header.astro';
import Hero from '../components/home/Hero.astro';
import Trust from '../components/home/Trust.astro';
import Benefits from '../components/home/Benefits.astro';
import Services from '../components/home/Services.astro';
import Products from '../components/home/Products.astro';
import About from '../components/home/About.astro';
import Process from '../components/home/Process.astro';
import Pricing from '../components/home/Pricing.astro';
import Contact from '../components/home/Contact.astro';
import Footer from '../components/home/Footer.astro';
import GeoFocus from '../components/geo/GeoFocus.astro';
import { getGeoPath, latamRegions } from '../data/geo';
import type { Locale } from '../i18n';

export function getStaticPaths() {
  return latamRegions.map((region) => ({
    params: { geo: region.slug },
    props: { region },
  }));
}

const locale: Locale = 'es';
const { region } = Astro.props;
const healthHref = getGeoPath('health', region);
const copy = region.home;
---

<BaseLayout
  locale={locale}
  page="home"
  title={copy.title}
  description={copy.description}
  keywords={copy.keywords}
  theme="home"
  canonicalPath={getGeoPath('home', region)}
  placename={region.name}
  geoRegionCode={region.hreflang.replace('es-', '')}
  hreflang={region.hreflang}
>
  <Header locale={locale} />
  <main>
    <Hero
      locale={locale}
      tag={copy.heroTag}
      subtitle={copy.heroSubtitle}
      healthHref={healthHref}
    />
    <GeoFocus region={region} kind="home" />
    <Trust locale={locale} />
    <Benefits locale={locale} />
    <Services locale={locale} />
    <Products locale={locale} />
    <About locale={locale} />
    <Process locale={locale} />
    <Pricing locale={locale} />
    <Contact locale={locale} />
  </main>
  <Footer locale={locale} />
</BaseLayout>
