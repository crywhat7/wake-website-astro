---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import Header from '../../../components/health/Header.astro';
import Hero from '../../../components/health/Hero.astro';
import Problems from '../../../components/health/Problems.astro';
import Solution from '../../../components/health/Solution.astro';
import Modules from '../../../components/health/Modules.astro';
import Gallery from '../../../components/health/Gallery.astro';
import Pricing from '../../../components/health/Pricing.astro';
import CTA from '../../../components/health/CTA.astro';
import Footer from '../../../components/health/Footer.astro';
import GeoFocus from '../../../components/geo/GeoFocus.astro';
import { SITE } from '../../../data/site';
import { getGeoPath, usRegions } from '../../../data/geo';
import type { Locale } from '../../../i18n';

export function getStaticPaths() {
  return usRegions.map((region) => ({
    params: { geo: region.slug },
    props: { region },
  }));
}

const locale: Locale = 'en';
const { region } = Astro.props;
const copy = region.health;
---

<BaseLayout
  locale={locale}
  page="health"
  title={copy.title}
  description={copy.description}
  keywords={copy.keywords}
  image={SITE.assets.gallery[0].src}
  theme="home"
  canonicalPath={getGeoPath('health', region)}
  placename={region.name}
  geoRegionCode="US"
  hreflang={region.hreflang}
>
  <Header locale={locale} />
  <main>
    <Hero locale={locale} tag={copy.heroTag} subtitle={copy.heroSubtitle} />
    <GeoFocus region={region} kind="health" />
    <Problems locale={locale} />
    <Solution locale={locale} />
    <Modules locale={locale} />
    <Gallery locale={locale} />
    <Pricing locale={locale} />
    <CTA locale={locale} />
  </main>
  <Footer locale={locale} />

  <script is:inline src="https://cdn.paddle.com/paddle/v2/paddle.js"></script>
  <script is:inline define:vars={{ token: SITE.paddle.token }}>
    if (typeof Paddle !== 'undefined') {
      Paddle.Setup({ token });
    }
  </script>
</BaseLayout>
