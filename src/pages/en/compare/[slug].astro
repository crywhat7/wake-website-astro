---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import CompareHeader from '../../../components/compare/CompareHeader.astro';
import CompareContent from '../../../components/compare/CompareContent.astro';
import Footer from '../../../components/home/Footer.astro';
import { comparePages, getCompareLocale, getComparePath } from '../../../data/compare';
import type { Locale } from '../../../i18n';

export function getStaticPaths() {
  return comparePages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const locale: Locale = 'en';
const { page } = Astro.props;
const copy = getCompareLocale(page, locale);
---

<BaseLayout
  locale={locale}
  page="health"
  title={copy.title}
  description={copy.description}
  keywords={copy.keywords}
  theme="home"
  canonicalPath={getComparePath(locale, page.slug)}
  hreflang="en-US"
>
  <CompareHeader locale={locale} slug={page.slug} />
  <CompareContent locale={locale} page={page} />
  <Footer locale={locale} />
</BaseLayout>
