---
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';
import MonoTag from '../ui/MonoTag.astro';
import { SITE } from '../../data/site';
import { t, type Locale } from '../../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
---

<section id="contact" class="border-t border-wake-border-subtle py-32 max-lg:py-20">
  <Container class="grid gap-16 lg:grid-cols-[0.8fr_1.2fr]">
    <div>
      <MonoTag>{dict.home.contact.tag}</MonoTag>
      <h2
        class="mb-2 text-[clamp(2rem,4vw,2.75rem)] font-semibold leading-[1.15] tracking-tight text-wake-text"
      >
        {dict.home.contact.title}
      </h2>
      <p class="max-w-[600px] text-[17px] text-wake-muted">{dict.home.contact.subtitle}</p>
    </div>
    <form id="contactForm" class="flex flex-col gap-4" data-email={SITE.email} data-subject={dict.home.contact.mailSubject}>
      <div class="grid gap-4 sm:grid-cols-2">
        <div class="flex flex-col gap-1.5">
          <label for="name" class="text-xs font-medium text-wake-muted"
            >{dict.home.contact.name}</label
          >
          <input
            type="text"
            id="name"
            name="name"
            required
            class="rounded-lg border border-wake-border bg-white px-3.5 py-2.5 text-sm text-wake-text transition focus:border-wake-text focus:shadow-[0_0_0_1px_#0c0c0d] focus:outline-none"
          />
        </div>
        <div class="flex flex-col gap-1.5">
          <label for="company" class="text-xs font-medium text-wake-muted"
            >{dict.home.contact.company}</label
          >
          <input
            type="text"
            id="company"
            name="company"
            class="rounded-lg border border-wake-border bg-white px-3.5 py-2.5 text-sm text-wake-text transition focus:border-wake-text focus:shadow-[0_0_0_1px_#0c0c0d] focus:outline-none"
          />
        </div>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        <div class="flex flex-col gap-1.5">
          <label for="email" class="text-xs font-medium text-wake-muted"
            >{dict.home.contact.email}</label
          >
          <input
            type="email"
            id="email"
            name="email"
            required
            class="rounded-lg border border-wake-border bg-white px-3.5 py-2.5 text-sm text-wake-text transition focus:border-wake-text focus:shadow-[0_0_0_1px_#0c0c0d] focus:outline-none"
          />
        </div>
        <div class="flex flex-col gap-1.5">
          <label for="phone" class="text-xs font-medium text-wake-muted"
            >{dict.home.contact.phone}</label
          >
          <input
            type="tel"
            id="phone"
            name="phone"
            class="rounded-lg border border-wake-border bg-white px-3.5 py-2.5 text-sm text-wake-text transition focus:border-wake-text focus:shadow-[0_0_0_1px_#0c0c0d] focus:outline-none"
          />
        </div>
      </div>
      <div class="flex flex-col gap-1.5">
        <label for="message" class="text-xs font-medium text-wake-muted"
          >{dict.home.contact.message}</label
        >
        <textarea
          id="message"
          name="message"
          rows="4"
          class="min-h-[100px] resize-y rounded-lg border border-wake-border bg-white px-3.5 py-2.5 text-sm text-wake-text transition focus:border-wake-text focus:shadow-[0_0_0_1px_#0c0c0d] focus:outline-none"
        ></textarea>
      </div>
      <Button type="submit" class="mt-2 self-start !px-6 !py-3">{dict.home.contact.submit}</Button>
    </form>
  </Container>
</section>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement | null;
  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    const email = form.dataset.email ?? '';
    const subjectBase = form.dataset.subject ?? '';
    const name = (document.getElementById('name') as HTMLInputElement).value;
    const company = (document.getElementById('company') as HTMLInputElement).value;
    const userEmail = (document.getElementById('email') as HTMLInputElement).value;
    const phone = (document.getElementById('phone') as HTMLInputElement).value;
    const message = (document.getElementById('message') as HTMLTextAreaElement).value;

    const mailto = `mailto:${email}?subject=${encodeURIComponent(`${subjectBase} - ${name}`)}&body=${encodeURIComponent(
      `Nombre: ${name}\nEmpresa: ${company}\nEmail: ${userEmail}\nTeléfono: ${phone}\n\nMensaje:\n${message}`,
    )}`;
    window.open(mailto);
    form.reset();
  });
</script>
