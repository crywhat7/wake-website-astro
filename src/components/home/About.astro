---
import Container from '../ui/Container.astro';
import MonoTag from '../ui/MonoTag.astro';
import { t, type Locale } from '../../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
---

<section id="about" class="border-t border-wake-border-subtle py-32 max-lg:py-20">
  <Container class="grid items-start gap-16 lg:grid-cols-[0.9fr_1.1fr]">
    <div>
      <MonoTag>{dict.home.about.tag}</MonoTag>
      <h2
        class="mb-2 text-[clamp(2rem,4vw,2.75rem)] font-semibold leading-[1.15] tracking-tight text-wake-text"
      >
        {dict.home.about.title}
      </h2>
      <p class="max-w-[600px] text-[17px] text-wake-muted">{dict.home.about.subtitle}</p>
    </div>
    <div class="flex flex-col gap-8">
      {
        dict.home.about.pillars.map((p) => (
          <div class="border-b border-wake-border-subtle pb-4">
            <h4 class="mb-2 flex items-center gap-2 text-[15px] font-semibold">
              <i class={`fa-solid ${p.icon}`} />
              {p.title}
            </h4>
            <p class="text-sm leading-relaxed text-wake-muted">{p.desc}</p>
          </div>
        ))
      }
    </div>
  </Container>
</section>
