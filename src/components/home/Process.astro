---
import Container from '../ui/Container.astro';
import MonoTag from '../ui/MonoTag.astro';
import { t, type Locale } from '../../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
---

<section class="border-y border-wake-border bg-wake-subtle py-32 max-lg:py-20">
  <Container>
    <MonoTag>{dict.home.process.tag}</MonoTag>
    <h2
      class="mb-2 text-[clamp(2rem,4vw,2.75rem)] font-semibold leading-[1.15] tracking-tight text-wake-text"
    >
      {dict.home.process.title}
    </h2>
    <p class="mb-16 max-w-[600px] text-[17px] text-wake-muted">{dict.home.process.subtitle}</p>

    <div class="mt-8 grid gap-16 sm:grid-cols-2 lg:grid-cols-3">
      {
        dict.home.process.steps.map((s) => (
          <div>
            <span class="mb-2 block font-mono text-xs text-wake-light">{s.num}</span>
            <h3 class="mb-2 text-base font-semibold">{s.title}</h3>
            <p class="text-sm leading-relaxed text-wake-muted">{s.desc}</p>
          </div>
        ))
      }
    </div>
  </Container>
</section>
