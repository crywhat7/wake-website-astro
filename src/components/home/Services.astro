---
import Container from '../ui/Container.astro';
import MonoTag from '../ui/MonoTag.astro';
import { t, type Locale } from '../../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
---

<section id="services" class="border-y border-wake-border bg-wake-subtle py-32 max-lg:py-20">
  <Container>
    <MonoTag>{dict.home.services.tag}</MonoTag>
    <h2
      class="mb-2 text-[clamp(2rem,4vw,2.75rem)] font-semibold leading-[1.15] tracking-tight text-wake-text"
    >
      {dict.home.services.title}
    </h2>
    <p class="mb-16 max-w-[600px] text-[17px] font-normal text-wake-muted">
      {dict.home.services.subtitle}
    </p>

    <div class="mt-8 grid border-t border-l border-wake-border sm:grid-cols-2 lg:grid-cols-3">
      {
        dict.home.services.items.map((item) => (
          <article class="border-r border-b border-wake-border bg-white p-8 transition hover:bg-wake-card hover:shadow-[inset_0_-4px_0_#adfcdc] md:p-12 md:px-8">
            <i class={`fa-solid ${item.icon} mb-4 text-lg text-wake-text`} />
            <h3 class="mb-2 text-[17px] font-semibold tracking-tight">{item.title}</h3>
            <p class="text-sm leading-relaxed text-wake-muted">{item.desc}</p>
          </article>
        ))
      }
    </div>
  </Container>
</section>
