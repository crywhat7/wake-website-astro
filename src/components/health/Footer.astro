---
import Container from '../ui/Container.astro';
import LanguageSwitcher from '../ui/LanguageSwitcher.astro';
import GeoLinks from '../geo/GeoLinks.astro';
import { SITE } from '../../data/site';
import { t, getLocalizedPath, type Locale } from '../../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
const homePath = getLocalizedPath('home', locale);
const legalPath = getLocalizedPath('legal', locale);
const blogPath = getLocalizedPath('blog', locale);
---

<footer class="border-t border-wake-border bg-white pb-8 pt-16">
  <Container>
    <div
      class="grid gap-8 border-b border-wake-border-subtle pb-16 sm:grid-cols-2 lg:grid-cols-[1.4fr_1fr_1fr_1fr_1fr]"
    >
      <div>
        <a
          href="#hero"
          class="flex items-center gap-1.5 text-base font-bold tracking-tight text-wake-text no-underline"
        >
          WAKE HEALTH
          <span class="inline-block h-2 w-2 rounded-full bg-wake-accent-dark"></span>
        </a>
        <p class="mt-2 max-w-[240px] text-[13.5px] text-wake-muted">{dict.health.footer.brand}</p>
        <LanguageSwitcher locale={locale} page="health" class="mt-4" />
      </div>
      <div>
        <h5 class="mb-4 text-[13px] font-semibold text-wake-text">{dict.health.footer.company}</h5>
        <ul class="flex list-none flex-col gap-2">
          <li>
            <a
              href="#problemas"
              class="text-[13px] text-wake-muted no-underline hover:text-wake-text"
              >{dict.health.nav.problems}</a
            >
          </li>
          <li>
            <a href="#modulos" class="text-[13px] text-wake-muted no-underline hover:text-wake-text"
              >{dict.health.nav.modules}</a
            >
          </li>
          <li>
            <a href="#precios" class="text-[13px] text-wake-muted no-underline hover:text-wake-text"
              >{dict.health.pricing.tag}</a
            >
          </li>
          <li>
            <a href={homePath} class="text-[13px] text-wake-muted no-underline hover:text-wake-text"
              >{dict.health.footer.backHome}</a
            >
          </li>
          <li>
            <a href={blogPath} class="text-[13px] text-wake-muted no-underline hover:text-wake-text"
              >{dict.common.blog}</a
            >
          </li>
          <li>
            <a
              href={locale === 'es' ? '/comparar/wake-health-vs-excel' : '/en/compare/wake-health-vs-excel'}
              class="text-[13px] text-wake-muted no-underline hover:text-wake-text"
              >{locale === 'es' ? 'vs Excel' : 'vs Excel'}</a
            >
          </li>
          <li>
            <a
              href={locale === 'es' ? '/comparar/wake-health-vs-paper' : '/en/compare/wake-health-vs-paper'}
              class="text-[13px] text-wake-muted no-underline hover:text-wake-text"
              >{locale === 'es' ? 'vs Papel' : 'vs Paper'}</a
            >
          </li>
        </ul>
      </div>
      <GeoLinks locale={locale} kind="health" />
      <div>
        <h5 class="mb-4 text-[13px] font-semibold text-wake-text">{dict.health.footer.legal}</h5>
        <ul class="flex list-none flex-col gap-2">
          <li>
            <a
              href={`${legalPath}#terms`}
              class="text-[13px] text-wake-muted no-underline hover:text-wake-text"
              >{dict.health.footer.terms}</a
            >
          </li>
          <li>
            <a
              href={`${legalPath}#privacy`}
              class="text-[13px] text-wake-muted no-underline hover:text-wake-text"
              >{dict.health.footer.privacy}</a
            >
          </li>
          <li>
            <a
              href={`${legalPath}#refund`}
              class="text-[13px] text-wake-muted no-underline hover:text-wake-text"
              >{dict.health.footer.refund}</a
            >
          </li>
        </ul>
      </div>
      <div>
        <h5 class="mb-4 text-[13px] font-semibold text-wake-text">{dict.health.footer.location}</h5>
        <p class="text-[13px] leading-relaxed text-wake-muted">
          {dict.health.footer.locationText}<br />
          <a href={`mailto:${SITE.email}`} class="text-wake-text no-underline">{SITE.email}</a>
        </p>
      </div>
    </div>
    <div class="flex flex-wrap items-center justify-between gap-4 pt-8">
      <p class="text-xs text-wake-light">{dict.health.footer.copy}</p>
      <div class="flex gap-4">
        <a
          href={SITE.social.facebook}
          aria-label="Facebook"
          class="text-sm text-wake-muted hover:text-wake-text"
          ><i class="fab fa-facebook"></i></a
        >
        <a
          href={SITE.social.linkedin}
          aria-label="LinkedIn"
          class="text-sm text-wake-muted hover:text-wake-text"
          ><i class="fab fa-linkedin"></i></a
        >
        <a
          href={SITE.social.instagram}
          aria-label="Instagram"
          class="text-sm text-wake-muted hover:text-wake-text"
          ><i class="fab fa-instagram"></i></a
        >
      </div>
    </div>
  </Container>
</footer>
