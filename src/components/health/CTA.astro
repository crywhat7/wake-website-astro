---
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';
import MonoTag from '../ui/MonoTag.astro';
import { SITE, whatsappUrl } from '../../data/site';
import { t, type Locale } from '../../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
const wa = whatsappUrl(dict.health.cta.whatsappMsg);
---

<section id="contacto" class="border-t border-wake-border-subtle py-32 max-lg:py-20">
  <Container class="grid items-center gap-12 lg:grid-cols-[1.2fr_0.8fr]">
    <div>
      <MonoTag>{dict.health.cta.tag}</MonoTag>
      <h2
        class="mb-2 text-[clamp(2rem,4vw,2.75rem)] font-semibold leading-[1.15] tracking-tight text-wake-text"
      >
        {dict.health.cta.title}
      </h2>
      <p class="mb-8 max-w-[560px] text-[17px] text-wake-muted">{dict.health.cta.subtitle}</p>
      <div class="flex flex-wrap gap-4">
        <Button href={wa} target="_blank" rel="noopener noreferrer">
          {dict.health.cta.whatsapp}
          <i class="fa-brands fa-whatsapp text-sm"></i>
        </Button>
        <Button
          href={SITE.healthAppLogin}
          variant="secondary"
          target="_blank"
          rel="noopener noreferrer"
        >
          {dict.health.cta.try}
        </Button>
      </div>
    </div>
    <div
      class="rounded-xl border border-wake-border bg-wake-card p-8 shadow-[0_10px_30px_rgba(0,0,0,0.02)]"
    >
      <div class="mb-4 flex items-center justify-between">
        <span class="font-mono text-[11px] uppercase text-wake-light">DEMO</span>
        <span class="h-2 w-2 rounded-full bg-wake-accent-dark"></span>
      </div>
      <p class="mb-2 text-[15px] font-semibold text-wake-text">WAKE HEALTH</p>
      <p class="text-sm leading-relaxed text-wake-muted">{dict.health.solution.subtitle}</p>
    </div>
  </Container>
</section>
