---
import Container from '../ui/Container.astro';
import MonoTag from '../ui/MonoTag.astro';
import { t, type Locale } from '../../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = t(locale);
---

<section id="modulos" class="py-32 max-lg:py-20">
  <Container>
    <MonoTag>{dict.health.modules.tag}</MonoTag>
    <h2
      class="mb-2 text-[clamp(2rem,4vw,2.75rem)] font-semibold leading-[1.15] tracking-tight text-wake-text"
    >
      {dict.health.modules.title}
    </h2>
    <p class="mb-16 max-w-[600px] text-[17px] text-wake-muted">{dict.health.modules.subtitle}</p>

    <div class="mt-8 grid border-t border-l border-wake-border sm:grid-cols-2 lg:grid-cols-3">
      {
        dict.health.modules.items.map((item) => (
          <article class="border-r border-b border-wake-border bg-white p-8 transition hover:bg-wake-card hover:shadow-[inset_0_-4px_0_#adfcdc] md:p-10 md:px-8">
            <i class={`fa-solid ${item.icon} mb-4 text-lg text-wake-text`} />
            <h3 class="text-[17px] font-semibold tracking-tight">{item.title}</h3>
          </article>
        ))
      }
    </div>
  </Container>
</section>
