---
import {
  getAlternateUrls,
  getLocalizedPath,
  ogLocale,
  type Locale,
  type PageKey,
} from '../../i18n';
import { SITE } from '../../data/site';

interface Props {
  locale: Locale;
  page: PageKey;
  title: string;
  description: string;
  keywords: string;
  image?: string;
  type?: 'website' | 'product';
  /** Override canonical path for geo/landing pages */
  canonicalPath?: string;
  placename?: string;
  geoRegionCode?: string;
  hreflang?: string;
}

const {
  locale,
  page,
  title,
  description,
  keywords,
  image = SITE.assets.healthLogoSvg,
  type = 'website',
  canonicalPath: canonicalPathProp,
  placename,
  geoRegionCode,
  hreflang,
} = Astro.props;

const siteUrl = (Astro.site?.href ?? SITE.url).replace(/\/$/, '') + '/';
const canonicalPath = canonicalPathProp ?? getLocalizedPath(page, locale);
const canonical = new URL(canonicalPath, siteUrl).href;
const alternates = canonicalPathProp
  ? []
  : getAlternateUrls(page, siteUrl);
const xDefault = canonicalPathProp
  ? canonical
  : new URL(getLocalizedPath(page, 'es'), siteUrl).href;
const geoRegion =
  geoRegionCode ??
  (locale === 'es' ? SITE.location.geoRegionEs : SITE.location.geoRegionEn);
const place = placename ?? SITE.location.country;
---

<title>{title}</title>
<meta name="description" content={description} />
<meta name="keywords" content={keywords} />
<meta
  name="robots"
  content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
/>
<meta name="googlebot" content="index, follow" />
<meta name="author" content={SITE.name} />
<meta name="publisher" content={SITE.name} />
<link rel="canonical" href={canonical} />

{
  !canonicalPathProp && (
    <>
      {alternates.map(({ href, hreflang: hl }) => (
        <link rel="alternate" hreflang={hl} href={href} />
      ))}
      {alternates.map(({ href, locale: loc }) => (
        <link rel="alternate" hreflang={loc} href={href} />
      ))}
      <link rel="alternate" hreflang="x-default" href={xDefault} />
      <link rel="alternate" hreflang="es-MX" href={xDefault} />
      <link rel="alternate" hreflang="es-GT" href={xDefault} />
      <link rel="alternate" hreflang="es-SV" href={xDefault} />
      <link rel="alternate" hreflang="es-CR" href={xDefault} />
      <link rel="alternate" hreflang="es-PA" href={xDefault} />
      <link rel="alternate" hreflang="es-CO" href={xDefault} />
      <link rel="alternate" hreflang="es-US" href={xDefault} />
    </>
  )
}

{
  canonicalPathProp && hreflang && (
    <>
      <link rel="alternate" hreflang={hreflang} href={canonical} />
      <link rel="alternate" hreflang={locale} href={canonical} />
    </>
  )
}

<meta property="og:type" content={type} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={image} />
<meta property="og:image:alt" content={title} />
<meta property="og:locale" content={ogLocale[locale]} />
<meta
  property="og:locale:alternate"
  content={locale === 'es' ? 'en_US' : 'es_HN'}
/>

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={image} />

<meta name="geo.region" content={geoRegion} />
<meta name="geo.placename" content={place} />
<meta name="ICBM" content="14.0723, -87.1921" />
<meta name="language" content={locale === 'es' ? 'Spanish' : 'English'} />
<meta name="coverage" content="Honduras, Central America, Latin America, United States" />
<meta name="distribution" content="global" />
<meta name="rating" content="general" />
<meta name="revisit-after" content="3 days" />

<meta name="theme-color" content="#0c0c0d" />
<meta name="msapplication-TileColor" content="#0c0c0d" />
