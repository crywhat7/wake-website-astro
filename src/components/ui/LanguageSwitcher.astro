---
import {
  getLocalizedPath,
  localeLabels,
  locales,
  type Locale,
  type PageKey,
} from '../../i18n';

interface Props {
  locale: Locale;
  page: PageKey;
  class?: string;
  /** Optional per-locale href overrides (e.g. same blog post in both languages) */
  hrefs?: Partial<Record<Locale, string>>;
}

const { locale, page, class: className = '', hrefs } = Astro.props;
---

<nav
  class:list={['inline-flex items-center gap-1 rounded-md border border-wake-border p-0.5', className]}
  aria-label="Language"
>
  {
    locales.map((loc) => (
      <a
        href={hrefs?.[loc] ?? getLocalizedPath(page, loc)}
        hreflang={loc}
        lang={loc}
        class:list={[
          'rounded px-2.5 py-1 text-xs font-semibold no-underline transition-colors',
          loc === locale
            ? 'bg-wake-text text-white'
            : 'text-wake-muted hover:text-wake-text',
        ]}
        aria-current={loc === locale ? 'page' : undefined}
      >
        {localeLabels[loc]}
      </a>
    ))
  }
</nav>
